# ──────────────────────────────────────────────────────────────────────────────
# VDiscovery eDiscovery Platform — Environment Configuration
# Copy this file to .env and fill in your values before running docker-compose.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=vdiscovery
POSTGRES_USER=vdiscovery
POSTGRES_PASSWORD=<strong-password-here>

# Redis
REDIS_PASSWORD=<strong-password-here>

# MinIO object storage
MINIO_ROOT_USER=vdiscovery
MINIO_ROOT_PASSWORD=<strong-password-min-8-chars>
MINIO_BUCKET=vdiscovery-files

# JWT authentication
JWT_SECRET=<random-32+-character-string>

# CORS — set to your frontend domain in production
CORS_ORIGIN=http://localhost:5173

# Processing parallelism (number of concurrent document workers)
PROCESSOR_CONCURRENCY=4

# Frontend → backend URL (as seen from the browser)
VITE_API_URL=http://localhost:3001

# Optional: S3-compatible external storage (overrides MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# Optional: external Elasticsearch cluster
# ELASTICSEARCH_URL=https://my-cluster.es.io:443
# ELASTICSEARCH_API_KEY=

# Optional: Azure Cognitive Services OCR (higher quality than Tesseract)
# AZURE_VISION_ENDPOINT=
# AZURE_VISION_KEY=

# Optional: OpenAI for AI-assisted review
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Email notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@vdiscovery.com
